# The Commons — Environment Configuration
# Copy this to .env and fill in your values

# Core
SECRET_KEY=change-this-to-a-long-random-string
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=sqlite:///./the_commons.db

# Server
HOST=0.0.0.0
PORT=8000

# Media
MEDIA_DIR=./media
MAX_UPLOAD_MB=100

# Founding Authority
SOVEREIGN_KEY_HASH=
SOVEREIGN_SALT=

# Circle
MIN_CIRCLE_SIZE=3
CIRCLE_MAJORITY=0.51
CIRCLE_SUPERMAJORITY=0.67

# Fingerprint
FINGERPRINT_ENABLED=true
FINGERPRINT_AUTO_PUBLISH=true

# Commerce
TRANSACTION_FEE=1.00
PROFIT=false
